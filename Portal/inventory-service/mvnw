#!/bin/sh
# ----------------------------------------------------------------------------
# Maven Wrapper bootstrap script (POSIX).
# Ensures .mvn/wrapper/maven-wrapper.jar exists by downloading it when missing,
# then delegates to the Maven Wrapper main class.
# ----------------------------------------------------------------------------

set -e

BASE_DIR=$(cd "$(dirname "$0")" && pwd)
WRAPPER_JAR="$BASE_DIR/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_DOWNLOADER="$BASE_DIR/.mvn/wrapper/MavenWrapperDownloader.java"

if [ ! -f "$WRAPPER_JAR" ]; then
  if [ ! -f "$WRAPPER_DOWNLOADER" ]; then
    echo "Missing MavenWrapperDownloader.java" >&2
    exit 1
  fi
  echo "Downloading Maven Wrapper jar..."
  (cd "$BASE_DIR" && javac ".mvn/wrapper/MavenWrapperDownloader.java" && java -cp ".mvn/wrapper" MavenWrapperDownloader "$BASE_DIR")
fi

JAVA_CMD="${JAVA_HOME:+$JAVA_HOME/bin/}java"
exec "$JAVA_CMD" -jar "$WRAPPER_JAR" "$@"

